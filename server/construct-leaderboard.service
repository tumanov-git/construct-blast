[Unit]
Description=Construct Blast leaderboard API
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/construct-blast-leaderboard
Environment=PORT=8022
Environment=DATA_FILE=/var/lib/construct-blast/leaderboard.json
Environment=TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
EnvironmentFile=-/etc/construct-blast/construct-blast.env
EnvironmentFile=-/etc/construct-blast/leaderboard.env
ExecStart=/usr/local/bin/node /opt/construct-blast-leaderboard/leaderboard-server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
